<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Blog</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="container">

        <h1>Blog</h1>

        <a href="postcadas.html">
            <button>Criar Post</button>
        </a>

        <% posts.forEach(post => { %>

            <div class="post">

                <h2>
                    <%= post.titulo %>
                </h2>

                <h4>
                    <%= post.resumo %>
                </h4>

                <p>
                    <%= post.conteudo %>
                </p>

            </div>

        <% }) %>

    </div>

</body>
</html>